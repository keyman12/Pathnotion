# Copy to .env for local dev. Never commit .env.
#
# ── Dev vs prod ────────────────────────────────────────────────────────────────
#   NODE_ENV=development — Vite serves the web app on :5173, API on :4000, CORS on,
#                          static serving off, session cookie not secured.
#   NODE_ENV=production  — API serves the prebuilt web bundle from ../web/dist,
#                          CORS off (same-origin via nginx), session cookies secured,
#                          bind defaults to 127.0.0.1 (nginx is the public face).

# Server
PORT=4000
NODE_ENV=development

# Bind address. Defaults: 0.0.0.0 in dev (handy for LAN testing from phones etc.),
# 127.0.0.1 in prod. Override when running on a machine where nginx is on another host.
# HOST=127.0.0.1

# Origin for CORS + cookies in dev (ignored in prod).
WEB_ORIGIN=http://localhost:5173

# Session
SESSION_SECRET=replace-me-with-a-long-random-string

# SQLite file (absolute path or relative to api/). Defaults to api/data/pathnotion.db.
# Prod suggestion: put it outside the repo so it survives redeploys.
# DATABASE_FILE=/var/lib/pathnotion/pathnotion.db

# Initial seed password (only used by `npm run seed` to set founder accounts)
SEED_PASSWORD=pathnotion

# Bootstrap admin if users table is empty (only read by `npm run db:init`)
ADMIN_USERNAME=dave
ADMIN_PASSWORD=change-me

# Founders (emails, display only — login is by username)
FOUNDER_D_EMAIL=dave@example.com
FOUNDER_R_EMAIL=raj@example.com

# Jeff agent — required for chat + weekly summary + article scans.
# Without a key, Jeff falls back to body-excerpt summaries during scans, and the chat endpoint returns 503.
ANTHROPIC_API_KEY=
# Optional model override — defaults to the latest Sonnet.
# JEFF_MODEL=claude-sonnet-4-5

# SMTP (Fasthosts Livemail in prod — daily digest)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# S3 (attachments) — not used yet
S3_BUCKET=
S3_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
