# Copy to .env and fill in. Never commit .env.

# Postgres
DATABASE_URL=postgres://localhost:5432/pathnotion

# S3 (file attachments)
S3_BUCKET=pathnotion-dev
S3_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:4000/api/auth/google/callback

# Jeff agent
ANTHROPIC_API_KEY=

# Server
PORT=4000
SESSION_SECRET=replace-me-with-a-long-random-string

# Founders (whitelist — only these two emails can sign in)
FOUNDER_D_EMAIL=dave@example.com
FOUNDER_R_EMAIL=raj@example.com
